{
  // Версия формата конфигурации
  "config_version": 1,

  "apps": {
    "alice": {

      "ads": {

        // Главный выключатель рекламы.
        // false = полностью отключить всю рекламу
        "enabled": true,

        // Показывать баннер внизу приложения.
        "banner": true,

        // Показывать межстраничную рекламу.
        "interstitial": true,

        // Через сколько запусков приложения
        // впервые разрешить показ межстраничной рекламы.
        //
        // 1 = с первого запуска
        // 3 = начиная с третьего запуска
        // 10 = начиная с десятого запуска
        "start_after_launches": 3,

        // Показывать каждое N-е рекламное событие.
        //
        // 1 = каждый раз
        // 2 = каждый второй раз
        // 5 = каждый пятый раз
        "interval": 5,

        // Минимальный интервал между двумя показами
        // межстраничной рекламы (в секундах).
        //
        // 0 = без задержки
        // 60 = не чаще одного раза в минуту
        // 120 = не чаще одного раза в две минуты
        "cooldown": 120,

        // Максимальное количество показов
        // межстраничной рекламы за один запуск приложения.
        //
        // После полного закрытия приложения
        // счетчик начинается заново.
        "max_per_session": 50
      },

      "app": {

        // Минимальная версия приложения.
        // Если версия ниже — можно показать сообщение
        // о необходимости обновления.
        "min_version": 1,

        // Сообщение пользователю.
        // Пока не используется.
        "message": ""
      }
    }
  }
}
